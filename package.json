{
  "name": "tsarr",
  "version": "2.7.4",
  "author": "Robbe Verhelst",
  "repository": {
    "type": "git",
    "url": "https://github.com/robbeverhelst/tsarr.git"
  },
  "bin": {
    "tsarr": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@hey-api/openapi-ts": "^0.96.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "^1.3.12",
    "semantic-release": "^25.0.3",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./radarr": {
      "import": "./dist/clients/radarr.js",
      "types": "./dist/clients/radarr.d.ts"
    },
    "./sonarr": {
      "import": "./dist/clients/sonarr.js",
      "types": "./dist/clients/sonarr.d.ts"
    },
    "./lidarr": {
      "import": "./dist/clients/lidarr.js",
      "types": "./dist/clients/lidarr.d.ts"
    },
    "./readarr": {
      "import": "./dist/clients/readarr.js",
      "types": "./dist/clients/readarr.d.ts"
    },
    "./prowlarr": {
      "import": "./dist/clients/prowlarr.js",
      "types": "./dist/clients/prowlarr.d.ts"
    },
    "./bazarr": {
      "import": "./dist/clients/bazarr.js",
      "types": "./dist/clients/bazarr.d.ts"
    },
    "./qbittorrent": {
      "import": "./dist/clients/qbittorrent.js",
      "types": "./dist/clients/qbittorrent.d.ts"
    },
    "./seerr": {
      "import": "./dist/clients/seerr.js",
      "types": "./dist/clients/seerr.d.ts"
    },
    "./radarr/types": {
      "types": "./dist/clients/radarr-types.d.ts"
    },
    "./sonarr/types": {
      "types": "./dist/clients/sonarr-types.d.ts"
    },
    "./lidarr/types": {
      "types": "./dist/clients/lidarr-types.d.ts"
    },
    "./readarr/types": {
      "types": "./dist/clients/readarr-types.d.ts"
    },
    "./prowlarr/types": {
      "types": "./dist/clients/prowlarr-types.d.ts"
    },
    "./bazarr/types": {
      "types": "./dist/clients/bazarr-types.d.ts"
    },
    "./qbittorrent/types": {
      "types": "./dist/clients/qbittorrent-types.d.ts"
    },
    "./seerr/types": {
      "types": "./dist/clients/seerr-types.d.ts"
    }
  },
  "description": "Type-safe TypeScript SDK for Servarr APIs (Radarr, Sonarr, etc.)",
  "engines": {
    "node": ">=24.14.1"
  },
  "files": [
    "dist",
    "!dist/binaries"
  ],
  "keywords": [
    "servarr",
    "radarr",
    "sonarr",
    "lidarr",
    "readarr",
    "prowlarr",
    "bazarr",
    "qbittorrent",
    "seerr",
    "jellyseerr",
    "overseerr",
    "typescript",
    "sdk",
    "api",
    "bun",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun run generate && bun run generate:types && bun run build:js && bun run build:cli && bun run build:types",
    "build:js": "bun build src/index.ts --outdir dist --target node --minify --splitting && bun build src/clients/radarr.ts --outdir dist/clients --target node --format esm && bun build src/clients/sonarr.ts --outdir dist/clients --target node --format esm && bun build src/clients/lidarr.ts --outdir dist/clients --target node --format esm && bun build src/clients/readarr.ts --outdir dist/clients --target node --format esm && bun build src/clients/prowlarr.ts --outdir dist/clients --target node --format esm && bun build src/clients/bazarr.ts --outdir dist/clients --target node --format esm && bun build src/clients/qbittorrent.ts --outdir dist/clients --target node --format esm && bun build src/clients/seerr.ts --outdir dist/clients --target node --format esm",
    "build:cli": "bun build src/cli/index.ts --outdir dist/cli --target node --format esm && chmod +x dist/cli/index.js",
    "build:types": "tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "dev": "bun run src/index.ts",
    "cli": "bun run src/cli/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "generate": "bun run scripts/generate.ts",
    "refresh:specs": "bun run scripts/refresh-specs.ts",
    "generate:types": "bun run scripts/generate-type-exports.ts",
    "generate:radarr": "bun run scripts/generate-radarr.ts",
    "generate:sonarr": "bun run scripts/generate-sonarr.ts",
    "clean": "rm -rf src/generated && rm -rf dist",
    "docs": "typedoc",
    "docs:serve": "typedoc --serve",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "update-packaging": "bun run scripts/update-packaging.ts"
  },
  "sideEffects": false,
  "type": "module",
  "types": "dist/index.d.ts",
  "dependencies": {
    "citty": "^0.2.2",
    "consola": "^3.4.2"
  }
}
