{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)"
  ],
  "timezone": "Europe/Brussels",
  "assignees": [
    "robbeverhelst"
  ],
  "reviewers": [
    "robbeverhelst"
  ],
  "packageRules": [
    {
      "rangeStrategy": "bump",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "groupName": "Biome",
      "matchPackageNames": [
        "@biomejs/biome"
      ]
    },
    {
      "groupName": "TypeScript",
      "matchPackageNames": [
        "typescript"
      ]
    },
    {
      "groupName": "Bun",
      "matchPackageNames": [
        "@types/bun",
        "oven-sh/setup-bun"
      ]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  }
}
