{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "tarballDir": "dist"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/*.tgz",
            "label": "Tsarr NPM Package"
          },
          {
            "path": "dist/binaries/tsarr-linux-x64",
            "label": "Tsarr Linux x64"
          },
          {
            "path": "dist/binaries/tsarr-linux-arm64",
            "label": "Tsarr Linux arm64"
          },
          {
            "path": "dist/binaries/tsarr-darwin-x64",
            "label": "Tsarr macOS x64"
          },
          {
            "path": "dist/binaries/tsarr-darwin-arm64",
            "label": "Tsarr macOS arm64"
          },
          {
            "path": "dist/binaries/tsarr-windows-x64.exe",
            "label": "Tsarr Windows x64"
          }
        ]
      }
    ]
  ]
}
